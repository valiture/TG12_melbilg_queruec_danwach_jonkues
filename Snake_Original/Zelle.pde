class Zelle{
  private int x;
  private int y;
  public color DARK_G = color(162, 209, 73);
  public color LIGHT_G = color(170, 215, 81);

  
  public Zelle(int x, int y) {
    this.x = x;
    this.y = y;
  }
  public int getX() {
    return x;
  }
  public int getY() {
    return y;
  }
  public void setX(int x) {
    this.x = x;
  }
  public void setY(int y) {
    this.y = y;
  }
  
  
    
}
